<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.ComfyUIDrilldownControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:GoogleCalendarManagement.ViewModels">

    <StackPanel
        Padding="12"
        Spacing="12">

        <!-- Folder management -->
        <StackPanel Spacing="4">
            <TextBlock
                FontWeight="SemiBold"
                Text="Output Folders" />

            <ItemsControl ItemsSource="{Binding Folders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ComfyUIFolderItemViewModel">
                        <Grid
                            Padding="0,2"
                            ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Opacity="0.8"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding FolderPath}"
                                TextTrimming="CharacterEllipsis"
                                ToolTipService.ToolTip="{Binding FolderPath}" />
                            <Button
                                Grid.Column="1"
                                Padding="6,2"
                                Command="{Binding RemoveCommand}"
                                Content="Remove"
                                FontSize="11" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button
                HorizontalAlignment="Stretch"
                Command="{Binding AddFolderCommand}"
                Content="Add Folder…" />
        </StackPanel>

        <!-- Scan button + status -->
        <StackPanel Spacing="4">
            <Button
                HorizontalAlignment="Stretch"
                Command="{Binding ScanFoldersCommand}"
                Content="Import…" />
            <TextBlock
                Opacity="0.6"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding ScanStatusMessage}"
                TextWrapping="WrapWholeWords"
                Visibility="{Binding ScanStatusVisibility}" />
        </StackPanel>

        <!-- 24-hour timeline -->
        <ScrollViewer
            MaxHeight="360"
            HorizontalScrollMode="Disabled"
            Visibility="{Binding PointsVisibility}">
            <Canvas
                x:Name="TimelineCanvas"
                Width="200"
                Height="480" />
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock
            Margin="0,8,0,0"
            Opacity="0.6"
            Text="No ComfyUI activity for this day."
            TextWrapping="WrapWholeWords"
            Visibility="{Binding EmptyStateVisibility}" />

        <!-- Create candidate events -->
        <Button
            HorizontalAlignment="Stretch"
            Command="{Binding CreateCandidateEventsCommand}"
            Content="Create Candidate Events"
            Style="{StaticResource AccentButtonStyle}" />

    </StackPanel>
</UserControl>
