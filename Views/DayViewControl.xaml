<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GoogleCalendarManagement.Views.DayViewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Pinned all-day event strip above the scrollable hourly timeline -->
        <StackPanel
            x:Name="AllDayPanel"
            Grid.Row="0"
            Padding="12,12,20,4"
            Spacing="4" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid x:Name="DayTimelineSurface">
                <Grid x:Name="DayGrid" Margin="12,0,20,12" />
                <Canvas
                    x:Name="CurrentTimeOverlayCanvas"
                    Margin="12,0,20,12"
                    IsHitTestVisible="False" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
