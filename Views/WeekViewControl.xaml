<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GoogleCalendarManagement.Views.WeekViewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="WeekTimedEventTemplate">
            <Border>
                <Grid>
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="White"
                        TextTrimming="CharacterEllipsis"
                        x:Name="CompactTextBlock" />
                    <StackPanel
                        Spacing="2"
                        x:Name="DetailedPanel">
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="White"
                            MaxLines="1"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap"
                            x:Name="TitleTextBlock" />
                        <TextBlock
                            FontSize="11"
                            Foreground="White"
                            x:Name="TimeTextBlock" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Frozen header: day names, sync dots, and all-day events -->
        <Grid
            x:Name="WeekHeaderGrid"
            Grid.Row="0"
            Padding="12,12,12,0" />

        <!-- Scrollable hourly timeline -->
        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <Grid
                x:Name="WeekBodySurface">
                <Grid
                    x:Name="WeekGrid"
                    Padding="12,0,12,12" />
                <controls:ItemsRepeater
                    x:Name="TimedEventsRepeater"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top" />
                <Canvas
                    x:Name="CurrentTimeOverlayCanvas"
                    IsHitTestVisible="False" />
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
