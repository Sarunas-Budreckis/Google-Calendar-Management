<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GoogleCalendarManagement.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer>
            <StackPanel
                MaxWidth="720"
                Margin="32"
                Spacing="20">
                <TextBlock
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Settings" />

                <Border
                    Padding="24"
                    CornerRadius="{StaticResource AppCornerRadiusLarge}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="Google Calendar" />

                        <TextBlock
                            Text="Connect your Google Calendar account to enable local calendar sync."
                            TextWrapping="WrapWholeWords" />

                        <TextBlock>
                            <Run Text="Status: " />
                            <Run Text="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay}" />
                        </TextBlock>

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="12">
                            <Button
                                Style="{StaticResource PrimaryAction}"
                                Content="Connect Google Calendar"
                                Command="{x:Bind ViewModel.ConnectGoogleCalendarCommand}"
                                Visibility="{x:Bind ViewModel.ConnectButtonVisibility, Mode=OneWay}" />

                            <Button
                                Content="Reconnect Google Calendar"
                                Command="{x:Bind ViewModel.DisconnectGoogleCalendarCommand}"
                                Visibility="{x:Bind ViewModel.ReconnectButtonVisibility, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel
                            Spacing="12"
                            Visibility="{x:Bind ViewModel.SyncControlsVisibility, Mode=OneWay}">
                            <TextBlock
                                Text="Manual sync pulls the default 6 months back and 1 month forward range into the local cache."
                                TextWrapping="WrapWholeWords" />

                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="12">
                                <Button
                                    Style="{StaticResource PrimaryAction}"
                                    Content="Sync with Google Calendar"
                                    Command="{x:Bind ViewModel.SyncWithGoogleCalendarCommand}" />

                                <Button
                                    Content="Cancel Sync"
                                    Command="{x:Bind ViewModel.CancelSyncCommand}"
                                    Visibility="{x:Bind ViewModel.CancelSyncButtonVisibility, Mode=OneWay}" />

                                <ProgressRing
                                    Width="24"
                                    Height="24"
                                    IsActive="{x:Bind ViewModel.IsSyncing, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.CancelSyncButtonVisibility, Mode=OneWay}" />
                            </StackPanel>

                            <TextBlock>
                                <Run Text="Status: " />
                                <Run Text="{x:Bind ViewModel.SyncStatusText, Mode=OneWay}" />
                            </TextBlock>

                            <TextBlock
                                Text="{x:Bind ViewModel.SyncProgressText, Mode=OneWay}" />

                            <TextBlock>
                                <Run Text="Last successful sync: " />
                                <Run Text="{x:Bind ViewModel.LastSyncText, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
