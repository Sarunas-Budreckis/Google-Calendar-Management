<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GoogleCalendarManagement.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer>
            <StackPanel
                MaxWidth="720"
                Margin="32"
                Spacing="20">
                <TextBlock
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Settings" />

                <Border
                    Padding="24"
                    CornerRadius="{StaticResource AppCornerRadiusLarge}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="Google Calendar" />

                        <TextBlock
                            Text="Connect your Google Calendar account to enable local calendar sync. Use the Sync button in the main top bar to refresh calendar data."
                            TextWrapping="WrapWholeWords" />

                        <TextBlock>
                            <Run Text="Status: " />
                            <Run Text="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay}" />
                        </TextBlock>

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="12">
                            <Button
                                Style="{StaticResource PrimaryAction}"
                                Content="Connect Google Calendar"
                                Command="{x:Bind ViewModel.ConnectGoogleCalendarCommand}"
                                Visibility="{x:Bind ViewModel.ConnectButtonVisibility, Mode=OneWay}" />

                            <Button
                                Content="Reconnect Google Calendar"
                                Command="{x:Bind ViewModel.DisconnectGoogleCalendarCommand}"
                                Visibility="{x:Bind ViewModel.ReconnectButtonVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Padding="24"
                    CornerRadius="{StaticResource AppCornerRadiusLarge}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="Data Sources" />

                        <TextBlock
                            Text="Configure a Toggl Track API token to import sleep entries into the local data source cache."
                            TextWrapping="WrapWholeWords" />

                        <PasswordBox
                            x:Name="TogglApiTokenBox"
                            Header="Toggl API token"
                            Password="{x:Bind ViewModel.TogglApiToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Paste Toggl Track API token" />

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="12">
                            <Button
                                Content="Save token"
                                Click="SaveTogglTokenButton_Click" />
                            <Button
                                Content="Test connection"
                                Click="TestTogglConnectionButton_Click"
                                IsEnabled="{x:Bind ViewModel.CanTestTogglConnection, Mode=OneWay}" />
                            <ProgressRing
                                Width="24"
                                Height="24"
                                IsActive="{x:Bind ViewModel.IsTestingTogglConnection, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.TogglConnectionProgressVisibility, Mode=OneWay}" />
                        </StackPanel>

                        <TextBlock
                            Text="{x:Bind ViewModel.TogglConnectionTestResult, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
