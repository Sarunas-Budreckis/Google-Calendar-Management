<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="GoogleCalendarManagement.Views.EventPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:GoogleCalendarManagement.Views.Converters"
    xmlns:models="using:GoogleCalendarManagement.Models"
    Title="Link to event"
    PrimaryButtonText="Link"
    SecondaryButtonText="Cancel"
    DefaultButton="None">

    <ContentDialog.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <CollectionViewSource
            x:Key="GroupedEventSource"
            Source="{Binding Groups}"
            IsSourceGrouped="True"
            ItemsPath="." />
    </ContentDialog.Resources>

    <StackPanel Width="400" MaxHeight="500" Spacing="8">

        <TextBox
            PlaceholderText="Search events…"
            Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <ListView
            ItemsSource="{Binding Source={StaticResource GroupedEventSource}}"
            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
            SelectionMode="Single"
            MaxHeight="380">

            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding Key}"
                                FontWeight="SemiBold"
                                Margin="0,4,0,2" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:EventPickerItem">
                    <StackPanel Orientation="Horizontal" Spacing="8" Padding="0,2">
                        <Rectangle
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            Fill="{x:Bind ColorHex, Converter={StaticResource HexToBrushConverter}}" />
                        <TextBlock
                            Text="{x:Bind Summary}"
                            VerticalAlignment="Center"
                            MaxWidth="200"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{x:Bind TimeRangeText}"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock
            Text="No events found"
            HorizontalAlignment="Center"
            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}" />

        <TextBlock
            Text="{Binding ErrorMessage}"
            Foreground="Red"
            TextWrapping="Wrap"
            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />

    </StackPanel>
</ContentDialog>
