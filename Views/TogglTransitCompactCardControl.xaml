<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.TogglTransitCompactCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel
            Spacing="2"
            Visibility="{Binding EntriesVisibility}">
            <TextBlock
                Opacity="0.76"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding TotalDurationLabel}"
                TextWrapping="NoWrap" />
            <TextBlock
                Opacity="0.76"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding TripCountLabel}"
                TextWrapping="NoWrap" />
        </StackPanel>

        <TextBlock
            Opacity="0.54"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="No driving data"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding NoEntriesVisibility}" />
    </Grid>
</UserControl>
