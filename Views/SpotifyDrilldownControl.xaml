<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.SpotifyDrilldownControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:GoogleCalendarManagement.Views">

    <StackPanel
        Padding="12"
        Spacing="12">

        <TextBlock
            FontWeight="SemiBold"
            Text="{Binding SummaryLabel}"
            Visibility="{Binding DataVisibility}"
            TextWrapping="WrapWholeWords" />

        <views:VerticalDotTimelineControl
            x:Name="Timeline"
            Visibility="{Binding DataVisibility}" />

        <TextBlock
            Margin="0,8,0,0"
            Opacity="0.6"
            Text="No Spotify streams for this day."
            TextWrapping="WrapWholeWords"
            Visibility="{Binding EmptyStateVisibility}" />
    </StackPanel>
</UserControl>
