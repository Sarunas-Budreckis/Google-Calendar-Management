<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.TogglSleepDrilldownControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel
        Padding="12"
        Spacing="12">
        <ItemsControl
            ItemsSource="{Binding Entries}"
            Visibility="{Binding EntriesVisibility}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,8"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Spacing="4">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    FontWeight="SemiBold"
                                    Text="{Binding TimeRangeLabel}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Grid.Column="1"
                                    Opacity="0.72"
                                    Text="{Binding DurationLabel}"
                                    TextWrapping="NoWrap" />
                                <Button
                                    Grid.Column="2"
                                    MinWidth="0"
                                    Padding="8,2"
                                    Command="{Binding AddCommand}"
                                    Content="Add"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Visibility="{Binding AddButtonVisibility}" />
                            </Grid>
                            <TextBlock
                                Opacity="0.72"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding Description}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock
            Margin="0,8,0,0"
            Opacity="0.6"
            Text="No sleep data for this day."
            TextWrapping="WrapWholeWords"
            Visibility="{Binding EmptyStateVisibility}" />

        <StackPanel
            Spacing="6"
            Visibility="{Binding QualityInputVisibility}">
            <TextBlock
                FontWeight="SemiBold"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Sleep Quality (0–10)" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <NumberBox
                    x:Name="QualityBox"
                    Grid.Column="0"
                    Minimum="0"
                    Maximum="10"
                    SpinButtonPlacementMode="Compact"
                    PlaceholderText="Not set"
                    ValueChanged="QualityBox_ValueChanged" />
                <Button
                    Grid.Column="1"
                    Content="Clear"
                    Click="ClearQuality_Click" />
            </Grid>
        </StackPanel>

        <Button
            HorizontalAlignment="Stretch"
            Command="{Binding CreateCandidateEventCommand}"
            Content="Generate Event"
            Style="{StaticResource AccentButtonStyle}" />
    </StackPanel>
</UserControl>
