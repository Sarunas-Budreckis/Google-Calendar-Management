<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.MapsTimelineDrilldownControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel
        Padding="12"
        Spacing="12">

        <ItemsControl
            ItemsSource="{Binding Segments}"
            Visibility="{Binding SegmentsVisibility}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,8"
                        Padding="10"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel Spacing="4">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    FontWeight="SemiBold"
                                    Text="{Binding TypeLabel}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Grid.Column="1"
                                    Opacity="0.72"
                                    Text="{Binding DurationLabel}"
                                    TextWrapping="NoWrap" />
                            </Grid>
                            <TextBlock
                                Opacity="0.76"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding StartLabel}"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                Opacity="0.76"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding EndLabel}"
                                TextWrapping="NoWrap" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock
            Margin="0,8,0,0"
            Opacity="0.6"
            Text="{Binding EmptyMessage}"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding EmptyStateVisibility}" />

        <Button
            HorizontalAlignment="Stretch"
            Command="{Binding CopyToViewerCommand}"
            Content="Copy to Viewer &amp; Open"
            Visibility="{Binding CopyButtonVisibility}" />

        <Button
            HorizontalAlignment="Stretch"
            Command="{Binding ImportCommand}"
            Content="Import Timeline" />

    </StackPanel>
</UserControl>
