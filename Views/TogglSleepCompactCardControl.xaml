<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.TogglSleepCompactCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel Visibility="{Binding EntriesVisibility}">
            <ItemsControl ItemsSource="{Binding Entries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            Margin="0,1"
                            ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Opacity="0.76"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding TimeRangeLabel}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                Grid.Column="1"
                                Opacity="0.76"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{Binding DurationLabel}"
                                TextWrapping="NoWrap" />
                            <Button
                                Grid.Column="2"
                                MinWidth="0"
                                Padding="5,1"
                                Command="{Binding AddCommand}"
                                Content="Add"
                                FontSize="11"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{Binding AddButtonVisibility}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock
                Opacity="0.76"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding QualityLabel}"
                TextWrapping="NoWrap"
                Visibility="{Binding QualityLabelVisibility}" />
        </StackPanel>

        <TextBlock
            Opacity="0.54"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="No sleep data"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding NoEntriesVisibility}" />
    </Grid>
</UserControl>
