<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.OutlookCompactCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel
            Spacing="2"
            Visibility="{Binding DataVisibility}">
            <TextBlock
                Opacity="0.76"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding EventCountLabel}"
                TextWrapping="NoWrap" />
            <TextBlock
                Opacity="0.76"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding WorkHoursLabel}"
                TextWrapping="NoWrap"
                Visibility="{Binding WorkHoursVisibility}" />
        </StackPanel>

        <TextBlock
            Opacity="0.54"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="No work events"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding NoDataVisibility}" />
    </Grid>
</UserControl>
