<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="GoogleCalendarManagement.Views.TogglPhoneRulesControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="560">

    <StackPanel
        Padding="4"
        Spacing="12">

        <ProgressRing
            IsActive="True"
            Visibility="{Binding LoadingVisibility}" />

        <ScrollViewer MaxHeight="360">
            <ItemsControl ItemsSource="{Binding Rules}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,0,8"
                            Padding="10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row 0: Description pattern and active toggle -->
                                <Grid Grid.Row="0" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        Header="Description Pattern"
                                        Text="{Binding DescriptionPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ToggleSwitch
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Header="Active"
                                        IsOn="{Binding IsActive, Mode=TwoWay}"
                                        OnContent="Yes"
                                        OffContent="No" />
                                </Grid>

                                <!-- Row 1: Max duration and date range pickers -->
                                <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        Header="Max Duration (min)"
                                        Text="{Binding MaxDurationMinutesText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="No limit"
                                        Width="140" />
                                    <CalendarDatePicker
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Header="From date"
                                        PlaceholderText="No start limit"
                                        Date="{Binding DateFromOffset, Mode=TwoWay}" />
                                    <CalendarDatePicker
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        Header="To date"
                                        PlaceholderText="No end limit"
                                        Date="{Binding DateToOffset, Mode=TwoWay}" />
                                </Grid>

                                <!-- Row 2: Notes and action buttons -->
                                <Grid Grid.Row="2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        Header="Notes"
                                        Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Optional notes" />
                                    <Button
                                        Grid.Column="1"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding SaveCommand}"
                                        Content="Save" />
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding DeactivateCommand}"
                                        Content="Deactivate" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Command="{Binding AddRuleCommand}"
                Content="+ Add Rule" />
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4">
                <ProgressRing
                    Width="20"
                    Height="20"
                    IsActive="True"
                    Visibility="{Binding ReclassifyingVisibility}" />
                <Button
                    Command="{Binding ReclassifyAllCommand}"
                    Content="Re-classify All" />
            </StackPanel>
        </Grid>

        <TextBlock
            Opacity="0.7"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{Binding StatusMessage}"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding StatusVisibility}" />

    </StackPanel>
</UserControl>
