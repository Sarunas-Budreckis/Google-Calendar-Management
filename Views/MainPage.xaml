<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="GoogleCalendarManagement.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="20"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel Spacing="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource TitleTextBlockStyle}"
                        Text="Calendar" />

                    <Button
                        x:Name="SettingsButton"
                        Grid.Column="1"
                        Click="SettingsButton_Click"
                        Content="Settings"
                        HorizontalAlignment="Right" />
                </Grid>

                <Border
                    Padding="4"
                    Background="{StaticResource CalendarSelectionBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource AppCornerRadiusLarge}"
                    HorizontalAlignment="Left">
                    <Grid
                        x:Name="ViewModeSelectorGrid"
                        ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            x:Name="ViewModeSelectionIndicator"
                            Grid.ColumnSpan="4"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Left"
                            Background="{StaticResource CalendarSelectionHoverBrush}"
                            CornerRadius="{StaticResource AppCornerRadiusMedium}"
                            RenderTransformOrigin="0,0" />

                        <Button
                            x:Name="YearViewButton"
                            Grid.Column="0"
                            MinWidth="76"
                            Click="ViewModeButton_Click"
                            Content="Year"
                            Padding="16,8"
                            Tag="Year" />

                        <Button
                            x:Name="MonthViewButton"
                            Grid.Column="1"
                            MinWidth="76"
                            Click="ViewModeButton_Click"
                            Content="Month"
                            Padding="16,8"
                            Tag="Month" />

                        <Button
                            x:Name="WeekViewButton"
                            Grid.Column="2"
                            MinWidth="76"
                            Click="ViewModeButton_Click"
                            Content="Week"
                            Padding="16,8"
                            Tag="Week" />

                        <Button
                            x:Name="DayViewButton"
                            Grid.Column="3"
                            MinWidth="76"
                            Click="ViewModeButton_Click"
                            Content="Day"
                            Padding="16,8"
                            Tag="Day" />
                    </Grid>
                </Border>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Width="44"
                        Click="PreviousButton_Click"
                        Content="←"
                        FontSize="18" />

                    <Button
                        Grid.Column="1"
                        Command="{x:Bind ViewModel.NavigateTodayCommand}"
                        Content="Today" />

                    <Button
                        Grid.Column="2"
                        Width="44"
                        Click="NextButton_Click"
                        Content="→"
                        FontSize="18" />

                    <CalendarDatePicker
                        x:Name="JumpToDatePicker"
                        Grid.Column="3"
                        Margin="12,0,0,0"
                        Header="Jump to date"
                        DateChanged="JumpToDatePicker_DateChanged" />

                    <Border
                        Grid.Column="4"
                        Margin="12,0,0,0"
                        Padding="12,6"
                        Background="{StaticResource CalendarSelectionBrush}"
                        CornerRadius="{StaticResource AppCornerRadiusLarge}"
                        VerticalAlignment="Center">
                        <TextBlock
                            Foreground="{StaticResource WhiteBrush}"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="{x:Bind ViewModel.BreadcrumbLabel, Mode=OneWay}" />
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Frame x:Name="CalendarFrame" Grid.Column="0" />

            <Border
                Grid.Column="0"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="{StaticResource AppCornerRadiusLarge}"
                Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}">
                <TextBlock
                    MaxWidth="420"
                    Text="No events synced yet. Go to Settings → Connect Google Calendar to sync."
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />
            </Border>

            <ProgressRing
                Grid.Column="0"
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

            <ContentControl
                x:Name="EventDetailsPanel"
                Grid.Column="1"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch" />
        </Grid>
    </Grid>
</Page>
